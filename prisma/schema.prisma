generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String         @id @default(cuid())
  walletAddress    String         @unique
  username         String         @unique
  avatar           String         @default("🌱")
  xpTotal          Int            @default(0)
  weeklyXp         Int            @default(0)
  weeklyDurationMs Int            @default(0)
  currentWeekKey   String         @default("")
  streak           Int            @default(0)
  lastPlayedAt     DateTime?
  locale           String         @default("es")
  region           String         @default("global")
  participationStreak    Int            @default(0)
  lastParticipatedWeekKey String        @default("")
  totalWeeksParticipated Int            @default(0)
  createdAt        DateTime       @default(now())
  attempts         DailyAttempt[]
  achievements     Achievement[]
  seasonEntries    WeeklySeasonEntry[]
  rewards          RewardDistribution[]
}

model Question {
  id           String                @id @default(cuid())
  category     String
  difficulty   Int                   @default(1)
  correctIndex Int
  translations QuestionTranslation[]
}

model QuestionTranslation {
  id          String   @id @default(cuid())
  questionId  String
  locale      String
  text        String
  options     String
  explanation String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
}

model DailyAttempt {
  id          String    @id @default(cuid())
  userId      String
  date        String
  weekKey     String    @default("")
  questionIds String
  answers     String    @default("[]")
  livesLeft       Int       @default(1)
  lifeRefillUsed  Boolean   @default(false)
  result          String    @default("in_progress")
  refillTxHash    String?
  refillToken     String?
  xpEarned        Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// Monday–Sunday competition season
model WeeklySeason {
  id                 String              @id @default(cuid())
  weekKey            String              @unique
  startDate          DateTime
  endDate            DateTime
  status             String              @default("active")
  finalizedAt        DateTime?
  rewardPaid         Boolean             @default(false)
  rewardWinnerWallet String?
  rewardAmount       String?
  rewardTxHash       String?
  rewardPaidAt       DateTime?
  entries            WeeklySeasonEntry[]
  achievements       Achievement[]
  rewards            RewardDistribution[]
}

model WeeklySeasonEntry {
  id            String       @id @default(cuid())
  seasonId      String
  userId        String
  username      String
  avatar        String
  walletAddress String
  xp            Int
  durationMs    Int
  rank          Int
  season        WeeklySeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
}

model Achievement {
  id          String        @id @default(cuid())
  userId      String
  seasonId    String?
  type        String
  title       String
  description String
  emoji       String
  // Future onchain fields
  nftTokenId  String?
  txHash      String?
  mintedAt    DateTime?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  season      WeeklySeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
}

model RewardDistribution {
  id            String       @id @default(cuid())
  seasonId      String
  userId        String
  walletAddress String
  rank          Int
  rewardType    String
  amount        String?
  status        String       @default("pending")
  txHash        String?
  createdAt     DateTime     @default(now())
  season        WeeklySeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  role          String   @default("ADMIN")
  createdAt     DateTime @default(now())
}

model Payment {
  id           String   @id @default(cuid())
  userWallet   String
  tokenAddress String
  tokenSymbol  String
  amount       String
  txHash       String   @unique
  createdAt    DateTime @default(now())

  @@index([userWallet])
  @@index([createdAt])
}
