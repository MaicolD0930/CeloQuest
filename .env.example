# Supabase PostgreSQL — replace YOUR_PASSWORD with your database password
# Project: db.fcecrahllkwyjycstbis.supabase.co

# ── Vercel / production (recommended) ───────────────────────
# Runtime: Transaction pooler (port 6543)
# DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migrations + local dev: Direct connection (port 5432)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.fcecrahllkwyjycstbis.supabase.co:5432/postgres?sslmode=require"

# Local dev can use direct for both; Vercel must use pooler for DATABASE_URL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.fcecrahllkwyjycstbis.supabase.co:5432/postgres?sslmode=require"

# ── Celo network ──────────────────────────────────────────────
# sepolia = testnet (tCOPM) · mainnet = production (cCOPM)
NEXT_PUBLIC_CELO_NETWORK=sepolia
CELO_NETWORK=sepolia
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# ── Life recovery payments ────────────────────────────────────
RECOVERY_DEMO_MODE=false
NEXT_PUBLIC_RECOVERY_DEMO_MODE=false
RECOVERY_TREASURY_ADDRESS=
NEXT_PUBLIC_RECOVERY_TREASURY=

# RecoveryPaymentContract — set after: npm run contracts:deploy:recovery
RECOVERY_CONTRACT_ADDRESS=
NEXT_PUBLIC_RECOVERY_CONTRACT_ADDRESS=

# CeloQuestRewards — set after: npm run contracts:deploy:rewards
REWARDS_CONTRACT_ADDRESS=
NEXT_PUBLIC_REWARDS_CONTRACT_ADDRESS=

# CeloQuestRewards — set after: npm run contracts:deploy:rewards
REWARDS_CONTRACT_ADDRESS=
NEXT_PUBLIC_REWARDS_CONTRACT_ADDRESS=
# Wallet allowed to call finalizeSeasonReward (cron/backend). Defaults to deployer.
# REWARDS_AUTOMATOR_ADDRESS=

# Vercel Cron — secures GET /api/cron/seasons (weekly auto payout)
# CRON_SECRET=

# Public URL for the app
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: defaults to RECOVERY_TREASURY / admin wallet
# REWARDS_ADMIN_ADDRESS=0x089189B7942588bDBAdcc5cFc8E76d8bd1073bd4

# tCOPM (Celo Sepolia) — set after: npm run contracts:deploy:tcopm
TCOPM_ADDRESS=
NEXT_PUBLIC_TCOPM_ADDRESS=

# USDC (Celo Sepolia official testnet)
USDC_ADDRESS=0x01C5C0122039549AD1493B8220cABEdD739BC44E
NEXT_PUBLIC_USDC_ADDRESS=0x01C5C0122039549AD1493B8220cABEdD739BC44E

# Recovery pricing ($0.10 USD per life; tCOPM uses live COP/USD rate)
RECOVERY_PRICE_USD_CENTS=10
NEXT_PUBLIC_RECOVERY_PRICE_USD_CENTS=10
# Optional fallback if FX API is down (normally fetched live)
# COP_PER_USD=
# EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
# COP_USD_CACHE_TTL_MS=3600000

# cCOPM (Celo Mainnet only — future production)
# CCOPM_ADDRESS=
# NEXT_PUBLIC_CCOPM_ADDRESS=

# ── Hardhat deploy (NEVER commit real keys) ───────────────────
DEPLOYER_PRIVATE_KEY=

# ── Dev / testing (local only — do NOT set on Vercel) ─────────
# Local / demo only — replay today's challenge without waiting for midnight reset
# ALLOW_DAILY_CHALLENGE_RETRY=true
